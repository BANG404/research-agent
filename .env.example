# Milvus — use ./milvus.db for Milvus Lite (no Docker needed)
# Switch to http://localhost:19530 if running full Milvus via Docker
# NOTE: APP_MILVUS_URI avoids collision with pymilvus's own MILVUS_URI env var
APP_MILVUS_URI=./milvus.db
APP_MILVUS_COLLECTION=aapl_10k

# Optional but recommended for tracing.
LANGSMITH_API_KEY=lsv2_...

# Embedding model (Qwen3-Embedding-8B via Gitee or compatible API)
EMBEDDING_OPENAI_API_KEY=your-embedding-api-key
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=Qwen3-Embedding-8B
EMBEDDING_DIMENSION=4096

# Reranker model (Qwen3-Reranker-8B via Gitee or compatible API)
RERANKER_OPENAI_API_KEY=your-reranker-api-key
RERANKER_OPENAI_BASE_URL=https://api.openai.com/v1
RERANKER_MODEL=Qwen3-Reranker-8B

# Chat LLM (OpenAI-compatible API)
CHAT_OPENAI_API_KEY=your-chat-api-key
CHAT_OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o

NEXT_PUBLIC_API_URL=http://localhost:2024
NEXT_PUBLIC_ASSISTANT_ID=agent